# ============================================================
# Regime — variabili d'ambiente
# Copia questo file in `.env` e compila i valori.
# ============================================================

# --- Database (OPZIONALE) ---
# Se NON imposti DATABASE_URL, l'app salva storico/transizioni su file JSON
# locali in data/artifacts/store/ (utile per sviluppo locale e per Lovable
# senza Supabase). Per produzione usa la connection string di Supabase.
#
# Supabase: Project Settings > Database > Connection string > URI
# Sostituisci il driver con "postgresql+psycopg" per usare psycopg v3.
# Esempio:
# DATABASE_URL=postgresql+psycopg://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=

# --- Parametri modello HMM ---
N_STATES=4                 # numero di regimi (stati nascosti) — configurabile
ROLLING_WINDOW=20          # finestra (giorni) per la volatilità rolling
MOMENTUM_WINDOW=10         # finestra (giorni) per il momentum / ROC
HMM_N_ITER=200             # iterazioni massime di training EM
RANDOM_SEED=42             # seed per riproducibilità

# --- Dati storici ---
HISTORY_LOOKBACK_DAYS=1825 # giorni di storico scaricati per il training (~5 anni)
MIN_OBSERVATIONS=120       # minimo di osservazioni richieste per addestrare l'HMM

# --- API / CORS ---
# Origini consentite per il frontend Lovable (separate da virgola).
# Usa "*" solo in sviluppo.
CORS_ORIGINS=*
